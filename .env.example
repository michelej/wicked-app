# Configuración para Despliegue en NAS
# Copia este archivo a .env y personaliza los valores

# ========================================
# GitHub Registry Configuration
# ========================================
# Reemplaza con tu usuario/repo de GitHub
GITHUB_REPOSITORY=michelejcs/wicked-app
DOCKER_REGISTRY=ghcr.io

# ========================================
# Base de Datos
# ========================================
# Nombre de la base de datos
MONGO_INITDB_DATABASE=wicked_db

# ========================================
# API Backend
# ========================================
# Puerto para el backend (por defecto 8000)
BACKEND_PORT=8000

# Orígenes CORS permitidos (separa con comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ========================================
# Frontend
# ========================================
# Puerto para el frontend (por defecto 5173)
FRONTEND_PORT=5173

# URL base del backend frontend
VITE_BACKEND_URL=http://localhost:8000

# ========================================
# MongoDB
# ========================================
# Puerto para MongoDB (por defecto 27017)
MONGODB_PORT=27017

# URL de conexión a MongoDB (generalmente no cambiar)
MONGODB_URL=mongodb://mongodb:27017


# Ubicación donde almacenar datos persistentes
# Ejemplo para NAS: /volume1/docker/wicked-app/data
DATA_PATH=./mongodb_data
